-- Exemplo de um Empréstimo Ativo (O João retirou o Multímetro)
-- Nota: Aqui usamos ID 2 para o João e ID 1 para a Ferramenta conforme a ordem acima
INSERT INTO emprestimos (usuarioId, ferramentaId, status) VALUES 
(2, 1, 'ativo');

-- Como o item acima foi emprestado, precisamos atualizar o status dele na tabela de ferramentas
UPDATE ferramentas SET status = 'em_uso' WHERE id = 1;

-- Buscar usuário pelo código de barras
SELECT id, nome, tipo FROM usuarios WHERE codBarras = '12345';

SELECT 
    f.nome AS ferramenta, 
    f.status, 
    u.nome AS usuario_com_a_posse
FROM ferramentas f
LEFT JOIN emprestimos e ON f.id = e.ferramentaId AND e.status = 'ativo'
LEFT JOIN usuarios u ON e.usuarioId = u.id;

SELECT 
    u.nome AS Funcionario, 
    f.nome AS Item, 
    e.dataRetirada, 
    e.dataDevolucao, 
    e.status AS Situacao_Emprestimo
FROM emprestimos e
JOIN usuarios u ON e.usuarioId = u.id
JOIN ferramentas f ON e.ferramentaId = f.id
ORDER BY e.dataRetirada DESC;