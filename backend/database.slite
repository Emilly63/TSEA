-- 1. Criação do Banco de Dados
CREATE DATABASE IF NOT EXISTS tsea_rastreabilidade;
USE tsea_rastreabilidade;

-- 2. Tabela de Usuários
-- Inclui o campo 'tipo' para diferenciar administradores de operadores
CREATE TABLE IF NOT EXISTS usuarios (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    senha VARCHAR(100),
    codBarras VARCHAR(50) UNIQUE NOT NULL, -- Nome esperado pelo backend
    setor VARCHAR(50),
    turno VARCHAR(50),
    tipo ENUM('operador', 'admin') DEFAULT 'operador' -- Define permissões
);

-- 3. Tabela de Ferramentas
-- O status inclui 'manutencao' conforme a lógica do seu server.js
CREATE TABLE IF NOT EXISTS ferramentas (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    codigoBarras VARCHAR(50) UNIQUE NOT NULL, -- Utilizado nas rotas de admin
    status ENUM('disponivel', 'em_uso', 'manutencao') DEFAULT 'disponivel',
    setor VARCHAR(50),
    localizacao VARCHAR(100)
);

-- 4. Tabela de Empréstimos
-- Registra o histórico e o vínculo entre usuários e ferramentas
CREATE TABLE IF NOT EXISTS emprestimos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    usuarioId INT,
    ferramentaId INT,
    dataRetirada DATETIME DEFAULT CURRENT_TIMESTAMP,
    dataDevolucao DATETIME NULL, -- Nome esperado para finalização
    status ENUM('ativo', 'concluido') DEFAULT 'ativo',
    FOREIGN KEY (usuarioId) REFERENCES usuarios(id),
    FOREIGN KEY (ferramentaId) REFERENCES ferramentas(id)
);

